<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>io.github.jianliang00.computer-use.agent</string>
  <key>ProgramArguments</key>
  <array>
    <string>/Applications/ComputerUseAgent.app/Contents/MacOS/computer-use-agent</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/Users/admin/Library/Logs/ComputerUseAgent.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/admin/Library/Logs/ComputerUseAgent.log</string>
</dict>
</plist>
